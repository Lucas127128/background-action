{
  "name": "background-action",
  "version": "1.0.5",
  "description": "Background processes: tail std(out|err), dedupe post-run lines. Monitor exit-code and file/port/socket/http(s) (un)readiness.",
  "keywords": [
    "Actions",
    "Background",
    "Command",
    "GitHub",
    "Logging",
    "Process",
    "wait-on"
  ],
  "homepage": "https://github.com/JarvusInnovations/background-action#readme",
  "bugs": {
    "url": "https://github.com/JarvusInnovations/background-action/issues"
  },
  "license": "Apache-2.0",
  "author": "Jeff Mealo <jeff.m@jarv.us>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/JarvusInnovations/background-action.git"
  },
  "type": "module",
  "main": "index.js",
  "scripts": {
    "lint": "oxlint",
    "build": "rolldown -c",
    "test": "vitest run",
    "all": "pnpm run lint && pnpm run build && pnpm run test",
    "clean": "rm -rf dist && rm -f ./**/*.err && rm -f ./**/*.out",
    "fmt": "oxfmt"
  },
  "dependencies": {
    "@actions/core": "^3.0.1",
    "parse-duration": "^1.1.2",
    "tail": "2.1.1",
    "wait-on": "^7.2.0"
  },
  "devDependencies": {
    "oxfmt": "^0.53.0",
    "oxlint": "^1.68.0",
    "rolldown": "^1.1.0",
    "sonda": "^0.11.1",
    "vitest": "^4.1.8"
  }
}
